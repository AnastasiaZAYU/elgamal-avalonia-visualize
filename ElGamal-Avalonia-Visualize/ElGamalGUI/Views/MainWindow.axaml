<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ElGamalGUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ElGamalGUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ElGamalGUI">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *, Auto, Auto" Margin="20">
		<StackPanel Grid.Row="0" Spacing="10">
			<TextBlock Text="ElGamal Crypto Tool" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <Button Content="Generate keys"
                    Command="{Binding GenerateKeysCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="40"/>

            <Grid ColumnDefinitions="*, *" Margin="0,5">
				<StackPanel Grid.Column="0" Margin="0,0,5,0">
					<TextBlock Text="System status: "/>
                    <TextBox Text="{Binding StatusMessage}" IsReadOnly="True" Background="#F0F0F0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="5,0,0,0">
					<TextBlock Text="Key parameters: "/>
                    <TextBox Text="KeyPair Generated" IsReadOnly="True"
                             IsEnabled="{Binding KeyPair, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                </StackPanel>
            </Grid>
            <Separator Margin="0,10"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="5">
			<TextBlock Text="Input message: "/>
            <TextBox Text="{Binding InputMessage}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="100"
                     Watermark="Enter text to encrypt..."/>
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="10" Margin="0,15,0,0">
			<Grid ColumnDefinitions="*, *">
				<Button Grid.Column="0"
                        Content="Ecrypt"
                        Command="{Binding EncryptCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,0,5,0"/>
                <Button Grid.Column="1"
                        Content="Decrypt"
                        Command="{Binding DecryptCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="5,0,0,0"/>
            </Grid>

            <Grid ColumnDefinitions="*, *">
				<Button Grid.Column="0"
                        Content="Sign"
                        Command="{Binding SignCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="#2D5A27"
                        Foreground="White"
                        Margin="0,0,5,0"/>
                <Button Grid.Column="1"
                        Content="Verify"
                        Command="{Binding VerifyCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="#1E3A5F"
                        Foreground="White"
                        Margin="5,0,0,0"/>
            </Grid>

            <TextBlock Text="Result: "/>
            <TextBox Text="{Binding ResultText}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="120"
                     IsReadOnly="False"
                     Watermark="The result of encryption/decryption will appear here..."/>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   FontSize="12"
                   Foreground="Gray"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Right"/>
    </Grid>


</Window>
