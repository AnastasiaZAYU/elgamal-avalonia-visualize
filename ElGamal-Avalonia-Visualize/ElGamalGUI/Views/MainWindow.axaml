<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ElGamalGUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ElGamalGUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ElGamalGUI">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ElGamal Crypto Tools (3072-bit)"
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto, *" Margin="0,5">
			<TextBlock Grid.Column="0" Text="P:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Grid.Column="1"
                     Text="{Binding PText}" 
                     IsReadOnly="True"
                     Margin="0,0,15,0"/>

            <TextBlock Grid.Column="2" Text="G:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Grid.Column="3" 
                     Text="{Binding GText}" 
                     IsReadOnly="True"/>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="Auto, *, Auto" Margin="0,5">
			<TextBlock Grid.Column="0" Text="Public Key:" VerticalAlignment="Center" Width="80"/>
            <TextBox Grid.Column="1" 
                     Text="{Binding PublicKeyText}" 
                     IsReadOnly="True"
                     Margin="0,0,10,0"/>

            <Button Grid.Column="2" 
                Content="Generate Parameters &amp; Keypair"
                Command="{Binding GenerateKeysCommand}"
                IsEnabled="{Binding !IsBusy}"
                Width="250"
                Height="34"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"/>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,5">
			<TextBlock DockPanel.Dock="Top" Text="Message:"/>
            <TextBox Text="{Binding InputMessage}" AcceptsReturn="True" TextWrapping="Wrap"/>
        </DockPanel>

        <DockPanel Grid.Row="4" Margin="0,5">
			<TextBlock DockPanel.Dock="Top" Text="Ciphertext:"/>
            <TextBox Text="{Binding CiphertextText}" AcceptsReturn="True" TextWrapping="Wrap"/>
        </DockPanel>
        
        <DockPanel Grid.Row="5" Margin="0,5">
			<TextBlock DockPanel.Dock="Top" Text="Signature:"/>
            <TextBox Text="{Binding SignatureText}" AcceptsReturn="True" TextWrapping="Wrap"/>
        </DockPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,10">
			<TextBlock Text="Is Valid?" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBox Text="{Binding IsValidText}" IsReadOnly="True" Width="150" Foreground="Gray"/>
        </StackPanel>

        <UniformGrid Grid.Row="7" Columns="4" Margin="0,10,0,0">
			<Button Content="Encrypt" 
                    Command="{Binding EncryptCommand}" 
                    IsEnabled="{Binding AreKeysGenerated}"
                    Margin="2"/>
            <Button Content="Decrypt" 
                    Command="{Binding DecryptCommand}"
                    IsEnabled="{Binding AreKeysGenerated}"
                    Margin="2"/>
            <Button Content="Sign" 
                    Command="{Binding SignCommand}"
                    IsEnabled="{Binding AreKeysGenerated}"
                    Margin="2"/>
            <Button Content="Verify" 
                    Command="{Binding VerifyCommand}" 
                    IsEnabled="{Binding AreKeysGenerated}"
                    Margin="2"/>
        </UniformGrid>

        <Border Grid.Row="8"
                Background="#F3F3F3"
                BorderBrush="Gray"
                BorderThickness="0,1,0,0"
                Margin="-20,20,-20,-20"
                Padding="10,5">
            <StackPanel Orientation="Horizontal">
				<TextBlock Text="Status: " FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Foreground="Black"/>

                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsBusy}"
                             Width="100"
                             Height="10"
                             Margin="15,0,0,0"
                             VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>